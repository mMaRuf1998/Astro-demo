---
const companiesImgSrc = [
    {
        name: "KR",
        src: "/logos/companies/kr.svg"
    },
    {
        name: "Savdo",
        src: "/logos/companies/savdo.svg"
    },
    {
        name: "Laklak",
        src: "/logos/companies/laklak.svg"
    },
    {
        name: "Brac",
        src: "/logos/companies/brac.svg"
    },
    {
        name: "Hulkenstein",
        src: "/logos/companies/hulk.svg"
    }
]
---

<div class="bg-white px-6 sm:px-8 py-16 md:py-20 text-center font-sans">
    <h3 class="mb-12 md:mb-16 text-xl sm:text-2xl md:text-[1.75rem] font-medium tracking-tight text-black text-balance">
        We’ve supported 10+ companies in reaching their goals.
    </h3>
    
    <div class="mx-auto flex flex-wrap justify-center max-w-[1200px] gap-px bg-gray-200 overflow-hidden rounded-xl">
        {
            companiesImgSrc.map((company) => (
                /* Responsive explicit basis allocations match your previous grid:
                  - w-[calc(50%-0.5px)]: 2 columns on mobile
                  - sm:w-[calc(33.333%-0.67px)]: 3 columns on tablet
                  - md:w-[calc(20%-0.8px)]: 5 columns on desktop
                */
                <div class="flex items-center justify-center h-[80px] md:h-[100px] px-6 md:px-10 box-border bg-white w-[calc(50%-0.5px)] sm:w-[calc(33.333%-0.67px)] md:w-[calc(20%-0.8px)] shrink-0 grow-0">
                    <img 
                        src={company.src} 
                        alt={company.name}
                        class="h-full w-full max-h-[35px] sm:max-h-[40px] md:max-h-[45px] object-contain filter grayscale opacity-60 transition-all duration-300 ease-in-out hover:filter-none hover:opacity-100 select-none" 
                    />
                </div>
            ))
        }
    </div>
</div>