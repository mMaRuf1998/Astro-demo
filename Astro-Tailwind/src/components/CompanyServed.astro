---

import kr from '../images/logos/companies/kr.svg';
import savdo from '../images/logos/companies/savdo.svg';
import laklak from '../images/logos/companies/laklak.svg';
import brac from '../images/logos/companies/brac.svg';
import hulk from '../images/logos/companies/hulk.svg';

const companiesImgSrc = [
    {
        name: "KR",
        src: kr.src
    },
    {
        name: "Savdo",
        src: savdo.src
    },
    {
        name: "Laklak",
        src: laklak.src
    },
    {
        name: "Brac",
        src: brac.src
    },
    {
        name: "Hulkenstein",
        src: hulk.src
    }
]
---


<div class="bg-white px-6 sm:px-8 py-16 md:py-20 text-center font-sans">
    <h3 class="mb-12 md:mb-16 text-xl sm:text-2xl md:text-[1.75rem] font-medium tracking-tight text-black text-balance">
        We’ve supported 10+ companies in reaching their goals.
    </h3>
    
    <div class="mx-auto flex flex-wrap justify-center max-w-[1200px] overflow-hidden rounded-xl bg-white select-none">
        
        <div class="flex items-center justify-center h-[140px] md:h-[160px] px-6 box-border bg-white w-1/2 lg:w-1/5 max-lg:border-b border-r border-gray-200">
            <div class="h-[50px] w-[130px] md:h-[50px] md:w-[150px] flex items-center justify-center">
                <img src={companiesImgSrc[0].src} alt={companiesImgSrc[0].name} class="h-full w-full object-contain" />
            </div>
        </div>

        <div class="flex items-center justify-center h-[140px] md:h-[160px] px-6 box-border bg-white w-1/2 lg:w-1/5 max-lg:border-b border-gray-200 md:border-r-0 lg:border-r">
            <div class="h-[50px] w-[130px] md:h-[50px] md:w-[150px] flex items-center justify-center">
                <img src={companiesImgSrc[1].src} alt={companiesImgSrc[1].name} class="h-full w-full object-contain" />
            </div>
        </div>

        <div class="flex items-center justify-center h-[140px] md:h-[160px] px-6 box-border bg-white w-1/2 lg:w-1/5 max-lg:border-b border-r border-gray-200">
            <div class="h-[50px] w-[130px] md:h-[50px] md:w-[150px] flex items-center justify-center">
                <img src={companiesImgSrc[2].src} alt={companiesImgSrc[2].name} class="h-full w-full object-contain" />
            </div>
        </div>

        <div class="flex items-center justify-center h-[140px] md:h-[160px] px-6 box-border bg-white w-1/2 lg:w-1/5 max-lg:border-b border-gray-200 lg:border-r">
            <div class="h-[65px] w-[130px] md:h-[80px] md:w-[150px] flex items-center justify-center">
                <img src={companiesImgSrc[3].src} alt={companiesImgSrc[3].name} class="h-full w-full object-contain" />
            </div>
        </div>

        <div class="flex items-center justify-center h-[140px] md:h-[160px] px-6 box-border bg-white w-full lg:w-1/5 max-lg:border-b border-gray-200">
            <div class="h-[60px] w-[200px] md:h-[65px] md:w-[150px] flex items-center justify-center">
                <img src={companiesImgSrc[4].src} alt={companiesImgSrc[4].name} class="h-full w-full object-contain" />
            </div>
        </div>

    </div>
</div>