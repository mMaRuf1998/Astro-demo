---
// src/components/serviceCard.astro
const { title, description, imageSrc, link } = Astro.props;
---

<div class="group flex flex-col items-center rounded-[32px] bg-white px-10 py-14 text-center text-black shadow-[0_10px_30px_rgba(0,0,0,0.02)] transition-all duration-300 ease-in-out hover:bg-[#655FF5] hover:text-white">
    <img 
        src={imageSrc} 
        alt={title} 
        class="mb-8 inline-block h-[100px] w-[100px] box-border rounded-full bg-[#f1f3f7] p-5 object-contain transition-colors duration-300 ease-in-out group-hover:bg-white/20"
    />
    
    <h2 class="mb-4 text-2xl font-semibold">{title}</h2>
    
    <p class="mb-8 text-[0.95rem] leading-[1.6] text-[#667085] transition-colors duration-300 ease-in-out group-hover:text-white/85">
        {description}
    </p>
    
    <a 
        href={link} 
        class="mt-auto font-medium text-[#655FF5] no-underline transition-colors duration-300 ease-in-out group-hover:text-white group-hover:underline"
    >
        Learn More
    </a>
</div>