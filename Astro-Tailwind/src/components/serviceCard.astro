---
// src/components/serviceCard.astro
const { title, description, imageSrc, link } = Astro.props;
---

<div class="group relative z-10 flex flex-col items-center rounded-[24px] sm:rounded-[32px] bg-white px-6 py-10 sm:px-10 sm:py-14 text-center text-black shadow-[0_10px_30px_rgba(0,0,0,0.02)] transition-all duration-300 ease-in-out hover:bg-[#655FF5] hover:text-white h-full cursor-pointer">
    
    <div class="mb-6 sm:mb-8 flex items-center justify-center h-20 w-20 sm:h-[100px] sm:w-[100px] rounded-full bg-[#f1f3f7] transition-all duration-300 ease-in-out group-hover:bg-white/20">
        <div 
            class="h-10 w-10 sm:h-12 sm:w-12 bg-[#05070f] transition-colors duration-300 group-hover:bg-white"
            style={`mask: url('${imageSrc}') no-repeat center / contain; -webkit-mask: url('${imageSrc}') no-repeat center / contain;`}
        ></div>
    </div>
    
    <h2 class="mb-3 sm:mb-4 text-xl sm:text-2xl font-semibold text-balance">{title}</h2>
    
    <p class="mb-6 sm:mb-8 text-sm sm:text-[0.95rem] leading-[1.6] text-[#667085] transition-colors duration-300 ease-in-out group-hover:text-white/85 text-pretty">
        {description}
    </p>
    
    <a 
        href={link} 
        class="mt-auto font-medium text-[#655FF5] no-underline transition-colors duration-300 ease-in-out group-hover:text-white group-hover:underline focus:outline-none focus:underline"
    >
        Learn More
    </a>
</div>