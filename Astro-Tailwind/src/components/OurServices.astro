---
import ServiceCard from "./serviceCard.astro";
import webDevelopment from "../images/logos/services/web_dark.svg"
import mobileApp from "../images/logos/services/app_dark.svg"
import ui_dark from "../images/logos/services/ui_dark.svg"

const services = [
  {
    id: 0,
    title: 'Web Development',
    description: 'Turning ideas into stunning websites and powerful web apps that drive business growth, visibility and user engagement.',
    imageSrc: webDevelopment.src,
    link: '/services#webapp-development',
  },
  {
    id: 1,
    title: 'Mobile App Development',
    description: 'Versatile mobile apps solution for a seamless Android and iOS experience, bringing your vision to life efficiently.',
    imageSrc: mobileApp.src,
    link: '/services#mobile-development',
  },
  {
    id: 2,
    title: 'UI/UX Design',
    description: 'Leverage our UI/UX expertise to create functional, stunning, and aesthetic designs that drive success.',
    imageSrc: ui_dark.src,
    link: '/services#ui-ux',
  },
];
---

<div class="bg-[#f8f9fa] px-6 sm:px-8 py-16 md:py-24 text-center font-sans">
    <h1 class="mb-3 text-4xl sm:text-5xl font-bold tracking-tight text-black">Our Services</h1>
    <p class="mx-auto mb-12 sm:mb-16 max-w-[650px] text-base sm:text-[1.1rem] leading-[1.5] text-[#535e72] text-pretty">
        We provide a comprehensive range of software development and product design services, driven by professionalism and excellence
    </p>
    
    <div class="mx-auto grid max-w-[1200px] grid-cols-[repeat(auto-fit,minmax(250px,1fr))] md:grid-cols-3 gap-6 md:gap-8 items-stretch">
        {services.map(service => (
            <ServiceCard 
                title={service.title} 
                description={service.description} 
                imageSrc={service.imageSrc} 
                link={service.link}
            />
        ))}
    </div>
</div>