---
interface ButtonItem {
    text: string;
    link: string;
}

interface Props {
    title: string;
    description: string;
    buttons?: ButtonItem[];
}

const { title, description, buttons } = Astro.props;
---

<div class="mx-auto flex max-w-[1200px] flex-col items-center justify-center px-8 pb-24 pt-[250px] text-center">
    <h1 
        set:html={title} 
        class="animate-item mb-8 text-4xl font-bold leading-[1.1] tracking-[-0.03em] text-white sm:text-6xl md:text-[5.5rem]"
        style="animation-delay: 0.1s;"
    />
    
    <p 
        set:html={description} 
        class="animate-item mb-12 max-w-[680px] text-base font-normal leading-relaxed text-slate-400 sm:text-lg md:text-xl"
        style="animation-delay: 0.25s;"
    />
    
    <div 
        class="animate-item flex items-center gap-5"
        style="animation-delay: 0.4s;"
    >
        {buttons &&
            buttons.map((button, index) => (
                <a 
                    href={button.link} 
                    class={
                        index === 0 
                            ? "inline-block rounded-full border border-transparent bg-[#5d5bf6] px-[2.2rem] py-[0.85rem] text-base font-medium text-white no-underline transition-all duration-300 ease-in-out hover:-translate-y-0.5 hover:bg-[#4b49dc] hover:shadow-[0_10px_25px_rgba(93,91,246,0.25)]" 
                            : "inline-block rounded-full border border-slate-700 bg-transparent px-[2.2rem] py-[0.85rem] text-base font-medium text-white no-underline transition-all duration-300 ease-in-out hover:-translate-y-0.5 hover:border-white hover:bg-white/5"
                    }
                >
                    {button.text}
                </a>
            ))
        }
    </div>
</div>

<style>
    /* Scoped cleanly only to this component */
    .animate-item {
        opacity: 0;
        animation: fadeInUp 0.8s cubic-bezier(0.25, 1, 0.5, 1) forwards;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px); 
        }
        to {
            opacity: 1;
            transform: translateY(0); 
        }
    }
</style>